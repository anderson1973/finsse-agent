# ═══════════════════════════════════════════════════════════════════════
# Finsse Agent — 环境变量
# 费用控制：MVP 阶段仅华为云 OCR 是必购项（约 ¥200/月）
#           其余所有服务在开发阶段使用 Mock/免费层
# ═══════════════════════════════════════════════════════════════════════

# ─── 运行模式 ──────────────────────────────────────────────────────────
# dev / production
NODE_ENV=development

# OCR 引擎: mock | huawei
# 开发阶段使用 mock（零成本），上线前设为 huawei
OCR_MODE=mock

# ─── Huawei Cloud OCR ———- MVP 阶段唯一需要付费的 OCR ──────────────────
# 华为云增值税发票识别 API: https://support.huaweicloud.com/api-ocr/ocr_03_0019.html
HUAWEI_OCR_ENDPOINT=https://ocr.cn-north-4.myhuaweicloud.com
HUAWEI_OCR_AK=
HUAWEI_OCR_SK=

# ─── DeepSeek API（AI Agent 推理，比 GPT-4 便宜 90%）──────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── 数据库（开发阶段用 Docker Compose 本地跑，免费）────────────────────
DATABASE_URL=postgresql://finsse:finsse_dev@localhost:5432/finsse

# ─── Redis（开发阶段用 Docker Compose 本地跑，免费）─────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── 用友 API（开发阶段 Mock，上线后按客户需开通）───────────────────────
YONYOU_API_URL=
YONYOU_APP_KEY=
YONYOU_APP_SECRET=

# ─── 金蝶 API（开发阶段 Mock，上线后按客户需开通）───────────────────────
KINGDEE_API_URL=
KINGDEE_APP_ID=
KINGDEE_APP_SECRET=

# ─── 微信小程序（认证费 ¥300/年，MVP 后期按需）─────────────────────────
WECHAT_APP_ID=
WECHAT_APP_SECRET=
